<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="webshopretrog.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="0"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="5024"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="atveteli_pontok" custom_title="0" dock_id="1" table="4,15:mainatveteli_pontok"/><dock_state state="000000ff00000000fd0000000100000002000005bb00000398fc0100000001fb000000160064006f0063006b00420072006f00770073006500310100000000000005bb0000012300ffffff000002690000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="atveteli_pontok" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="35"/><column index="2" value="103"/><column index="3" value="239"/><column index="4" value="300"/><column index="5" value="71"/><column index="6" value="82"/><column index="7" value="63"/><column index="8" value="63"/><column index="9" value="37"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">-- Tábla újra létrehozása (ez törli a régi tartalmat is)
DROP TABLE IF EXISTS rendelesosszesito;

-- Tábla létrehozása
CREATE TABLE rendelesosszesito (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    rendeles_szam TEXT UNIQUE,
    rendeles_datum DATETIME,
    vegosszeg REAL,
    szallitas_koltseg REAL,
    statusz TEXT,
    fizetes_statusz TEXT,
    
    szamlazo_nev TEXT,
    szamlazo_email TEXT,
    szamlazo_telefon TEXT,
    szamlazo_iranyitoszam TEXT,
    szamlazo_varos TEXT,
    szamlazo_cim TEXT,
    szamlazo_adoszam TEXT,
    szamlazo_cegnev TEXT,
    
    szallito_iranyitoszam TEXT,
    szallito_varos TEXT,
    szallito_cim TEXT,
    szallitas_mod TEXT,
    szallitas_pont_nev TEXT,
    szallitas_pont_cim TEXT,
    
    fizetes_mod TEXT,
    fizetes_osszeg REAL,
    
    eredeti_rendeles_id INTEGER,
    eredeti_szamlazasi_cim_id INTEGER,
    eredeti_szallitasi_cim_id INTEGER,
    eredeti_fizetes_id INTEGER,
    
    user_id INTEGER,
    letrehozva DATETIME DEFAULT CURRENT_TIMESTAMP
);

-- INSERT OR REPLACE használata
INSERT OR REPLACE INTO rendelesosszesito (
    rendeles_szam,
    rendeles_datum,
    vegosszeg,
    szallitas_koltseg,
    statusz,
    fizetes_statusz,
    
    szamlazo_nev,
    szamlazo_email,
    szamlazo_telefon,
    szamlazo_iranyitoszam,
    szamlazo_varos,
    szamlazo_cim,
    szamlazo_adoszam,
    szamlazo_cegnev,
    
    szallito_iranyitoszam,
    szallito_varos,
    szallito_cim,
    szallitas_mod,
    szallitas_pont_nev,
    szallitas_pont_cim,
    
    fizetes_mod,
    fizetes_osszeg,
    
    eredeti_rendeles_id,
    eredeti_szamlazasi_cim_id,
    eredeti_szallitasi_cim_id,
    eredeti_fizetes_id,
    
    user_id
)
SELECT 
    r.rendeles_szam,
    r.letrehozva,
    r.vegosszeg,
    r.szallitas_koltseg,
    r.statusz,
    r.fizetes_statusz,
    
    sz.nev,
    sz.email,
    sz.telefon,
    sz.iranyitoszam,
    sz.varos,
    sz.cim,
    sz.adoszam,
    sz.cegnev,
    
    st.iranyitoszam,
    st.varos,
    st.cim,
    r.szallitas_mod,
    r.szallitas_pont_nev,
    r.szallitas_pont_cim,
    
    r.fizetes_mod,
    r.vegosszeg,
    
    r.id,
    r.szamlazasi_cim_id,
    r.szallitasi_cim_id,
    f.id,
    
    r.user_id
FROM rendelesek r
LEFT JOIN szamlazasi_cimek sz ON r.szamlazasi_cim_id = sz.id
LEFT JOIN szallitasi_cimek st ON r.szallitasi_cim_id = st.id
LEFT JOIN fizetesek f ON f.rendeles_id = r.id
WHERE r.id IS NOT NULL;</sql><current_tab id="0"/></tab_sql></sqlb_project>
